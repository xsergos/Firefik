{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "datasource", "uid": "grafana" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Firefik overview: apply/reconcile latency + errors, drift, legacy cleanup, log-stream drops. Complements alerts in alerts/firefik.yml.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "Engine",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "description": "Reconcile cycle rate per second.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10, "drawStyle": "line" },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "targets": [
        {
          "expr": "rate(firefik_engine_reconcile_total[5m])",
          "legendFormat": "reconcile/s",
          "refId": "A"
        },
        {
          "expr": "rate(firefik_engine_reconcile_errors_total[5m])",
          "legendFormat": "errors/s",
          "refId": "B"
        }
      ],
      "title": "Reconcile rate (5m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "description": "Reconcile duration percentiles.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10, "drawStyle": "line" },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(firefik_engine_reconcile_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(firefik_engine_reconcile_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(firefik_engine_reconcile_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "Reconcile duration (s, 5m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "description": "Apply errors by failure phase (labels / backend / rehydrate / other).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10, "drawStyle": "line" },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "targets": [
        {
          "expr": "sum by (phase) (rate(firefik_engine_apply_errors_total[5m]))",
          "legendFormat": "{{phase}}",
          "refId": "A"
        }
      ],
      "title": "Apply errors by phase (5m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "description": "Apply duration percentiles labelled by result.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10, "drawStyle": "line" },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 4,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, result) (rate(firefik_engine_apply_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{result}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, result) (rate(firefik_engine_apply_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{result}}",
          "refId": "B"
        }
      ],
      "title": "Apply duration (s, 5m)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 101,
      "panels": [],
      "title": "State invariants",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "description": "Drift events per type (orphan / missing / wrong_rules). Only populated once v0.4 drift detection is shipped.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 20, "drawStyle": "bars" },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "id": 5,
      "targets": [
        {
          "expr": "sum by (type) (rate(firefik_engine_drift_total[15m]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ],
      "title": "Drift events (15m, by type)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "description": "Orphan chains removed (should spike once, stay at 0).",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 18 },
      "id": 6,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "expr": "sum(firefik_engine_orphans_cleaned_total)",
          "refId": "A"
        }
      ],
      "title": "Orphans cleaned (total)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "description": "Chains discovered at startup (pre-reconcile).",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 18 },
      "id": 7,
      "options": {
        "colorMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "expr": "firefik_engine_rehydrated_chains",
          "refId": "A"
        }
      ],
      "title": "Rehydrated chains (gauge)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "id": 102,
      "panels": [],
      "title": "Ops / hygiene",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "description": "Blue/green legacy cleanup errors (should stay at 0; any increase = manual intervention needed).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 20, "drawStyle": "bars" },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "id": 8,
      "targets": [
        {
          "expr": "sum by (suffix) (rate(firefik_engine_legacy_cleanup_errors_total[1h]))",
          "legendFormat": "{{suffix}}",
          "refId": "A"
        }
      ],
      "title": "Legacy cleanup errors (1h, by suffix)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "description": "Log-stream drop rate (slow WS consumer or hub overflow).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10, "drawStyle": "line" },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "id": 9,
      "targets": [
        {
          "expr": "rate(firefik_logstream_dropped_total[5m])",
          "legendFormat": "dropped/s",
          "refId": "A"
        }
      ],
      "title": "Log-stream drops (5m)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["firefik", "firewall", "docker"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Data source",
        "multi": false,
        "name": "DS_PROM",
        "options": [],
        "query": "prometheus",
        "queryValue": "",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Firefik — Overview",
  "uid": "firefik-overview",
  "version": 1,
  "weekStart": ""
}
