{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "datasource", "uid": "grafana" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Firefik control plane: agent connectivity, mTLS rejections, cert expiry, transport mix, audit + command throughput, db size. Pairs with alerts/firefik.yml and docs/metrics-guide.md.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "Connectivity",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 3 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 101,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "firefik_controlplane_grpc_agents_connected",
          "legendFormat": "agents",
          "refId": "A"
        }
      ],
      "title": "Connected agents",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 10,
            "spanNulls": true
          },
          "mappings": [
            { "options": { "-1": { "text": "disabled" } }, "type": "value" },
            { "options": { "0":  { "text": "backoff" } }, "type": "value" },
            { "options": { "0.5": { "text": "reconnecting" } }, "type": "value" },
            { "options": { "1":  { "text": "connected" } }, "type": "value" }
          ],
          "max": 1,
          "min": -1,
          "unit": "none"
        }
      },
      "gridPos": { "h": 6, "w": 18, "x": 6, "y": 1 },
      "id": 102,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "firefik_controlplane_connection_state",
          "legendFormat": "{{peer}} ({{transport}})",
          "refId": "A"
        }
      ],
      "title": "Connection state per agent",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10, "spanNulls": true },
          "unit": "rps"
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 7 },
      "id": 103,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (transport) (rate(firefik_controlplane_transport_requests_total[5m]))",
          "legendFormat": "{{transport}}",
          "refId": "A"
        }
      ],
      "title": "Transport mix (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "drawStyle": "bars", "fillOpacity": 60 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.001 }
            ]
          },
          "unit": "rps"
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 7 },
      "id": 104,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (reason) (rate(firefik_controlplane_mtls_rejected_total[5m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "title": "mTLS rejections (req/s)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 200,
      "panels": [],
      "title": "Certificates",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 7 },
              { "color": "yellow", "value": 14 },
              { "color": "green", "value": 30 }
            ]
          },
          "unit": "d"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 201,
      "options": {
        "displayMode": "gradient",
        "minVizHeight": 16,
        "minVizWidth": 0,
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "firefik_controlplane_agent_cert_days_until_expiry",
          "legendFormat": "{{agent_id}}",
          "refId": "A"
        }
      ],
      "title": "Days until cert expiry per agent",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 202,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(firefik_controlplane_ca_certs_issued_total[15m]) * 60",
          "legendFormat": "issued/min",
          "refId": "A"
        }
      ],
      "title": "Certs issued via /v1/enroll (per minute)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 300,
      "panels": [],
      "title": "Workload",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 301,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (kind) (rate(firefik_controlplane_commands_enqueued_total[5m]))",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ],
      "title": "Commands enqueued (req/s by kind)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "ops" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 302,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(firefik_controlplane_audit_events_total[5m])",
          "legendFormat": "audit",
          "refId": "A"
        }
      ],
      "title": "Audit events persisted (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1073741824 },
              { "color": "red", "value": 5368709120 }
            ]
          },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 32 },
      "id": 303,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "firefik_controlplane_db_bytes",
          "legendFormat": "sqlite",
          "refId": "A"
        }
      ],
      "title": "Control-plane sqlite size",
      "type": "stat"
    }
  ],
  "refresh": "30s",
